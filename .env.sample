# MiniMax API (used for both Graphiti entity extraction and MiroFish agents)
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_minimax_group_id

# MiroFish LLM (OpenAI-compatible format, points to MiniMax)
LLM_API_KEY=your_minimax_api_key
LLM_BASE_URL=https://api.minimaxi.chat/v1
LLM_MODEL_NAME=MiniMax-M2.5

# Neo4j (local Docker)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=prememora_local

# OpenViking (local server)
OPENVIKING_HOST=localhost
OPENVIKING_PORT=8000

# MiroFish (local Docker)
MIROFISH_BACKEND=http://localhost:5001
MIROFISH_FRONTEND=http://localhost:3000

